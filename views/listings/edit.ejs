<% layout("layouts/boilerplate.ejs") %>
    <div class="new-listing-page">
        <div class="row justify-content-center">
            <div class="col-8">
                <h3 class="text-center mb-4">Edit Listing</h3>
                <form method="POST" action="/listings/<%= listing._id %>?_method=PUT"
                    class="needs-validation p-4 bg-white rounded shadow-sm" novalidate enctype="multipart/form-data">

                    <div class="mb-3">
                        <label for="title" value="<%= listing.title %>">Title</label>
                        <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control"
                            required>
                        <div class="invalid-feedback">Title is required.</div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="listing[description]" class="form-control"
                            required> <%= listing.description %> </textarea>
                        <div class="invalid-feedback">Description is required.</div>
                    </div>
                    <div class="mb-3">
                        Original Image
                        <img src="<%=originalImageUrl %>" alt="">
                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label"> New Upload Image </label>
                        <input name="listing[image]" type="file" class="form-control" required>

                    </div>


                    <div class="mb-3">
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control"
                            required>
                        <div class="invalid-feedback">price is required.</div>
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="location" class="form-label">Location</label>
                            <input type="text" name="listing[location]" value="<%= listing.location %>"
                                class="form-control" required>
                            <div class="invalid-feedback">location is required.</div>
                        </div>
                        <div class="mb-3 col-md-8">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" name="listing[country]" value="<%= listing.country %>"
                                class="form-control" required>
                            <div class="invalid-feedback">country is required.</div>
                        </div>
                    </div>

                    <button class="btn btn-dark edit-btn">Edit</button>
                </form>
            </div>
        </div>
    </div>
    <script src="/js/script.js"></script>